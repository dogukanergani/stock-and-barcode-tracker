<Window x:Class="Otomasyon.GirisPaneli"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kaleli Tekel - Giriş" WindowState="Maximized" 
        Background="#121212" WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="KALELİ TEKEL" Foreground="#4CAF50" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtTarihSaat" Text="Yükleniyor..." Foreground="White" FontSize="24" Margin="0,10,0,40" HorizontalAlignment="Center"/>

            <Border Background="#1E1E1E" CornerRadius="20" Padding="40" Width="450">
                <StackPanel>
                    <TextBlock Text="Hoş Geldiniz" Foreground="Gray" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                    <Button Content="GÜNÜ BAŞLAT" Click="BtnGunBaslat_Click" Height="60" Background="#4CAF50" Foreground="White" FontWeight="Bold" FontSize="20"/>
                    <Button Content="ÇIKIŞ" Click="BtnKapat_Click" Height="40" Background="Transparent" Foreground="Gray" BorderThickness="0" Margin="0,20,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>