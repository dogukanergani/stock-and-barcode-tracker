                                <TextBlock x:Name="TxtSonFiyat" Text="0.00 ₺" Foreground="#10B981" FontSize="36" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Button Grid.Row="1" Content="SİGARA FARK (+3 ₺)" Click="BtnSigaraFark_Click" Background="#27272A" BorderThickness="1" BorderBrush="#3F3F46" Foreground="#D4D4D8" FontSize="18" Height="55" Margin="0,0,0,15"/>

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Button Grid.Row="0" Content="NAKİT (F1)" Click="BtnNakit_Click" Background="#10B981" FontSize="20" Margin="0,0,0,10"/>
                            <Button Grid.Row="1" Content="KART (F2)" Click="BtnKart_Click" Background="#3B82F6" FontSize="20" Margin="0,0,0,10"/>
                            <Button Grid.Row="2" Content="VERESİYE (F3)" Click="BtnVeresiye_Click" Background="#F59E0B" FontSize="20" Margin="0,0,0,10"/>
                            <Button Grid.Row="3" Content="PARÇALI (F4)" Click="BtnParcali_Click" Background="#8B5CF6" FontSize="20" Margin="0,0,0,10"/>
                            <Button Grid.Row="4" Content="SATIŞI İPTAL ET (ESC)" Click="BtnSatisIptal_Click" Background="Transparent" BorderThickness="1" BorderBrush="#EF4444" Foreground="#EF4444" FontSize="16" Margin="0,0,0,10"/>
                        </Grid>

                        <Button Grid.Row="3" Content="GÜNÜ KAPAT" Click="BtnGunKapat_Click" Height="60" Background="#7F1D1D" FontSize="18" Margin="0,10,0,0"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="STOK YÖNETİMİ">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#18181B" CornerRadius="16" Margin="0,0,20,0" Padding="15" Effect="{StaticResource ModernShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="KATEGORİ FİLTRESİ" Foreground="#10B981" FontSize="14" FontWeight="Bold" Margin="5,5,0,15"/>

                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                <TreeView x:Name="TreeKategoriler" Foreground="#FAFAFA" Background="Transparent" BorderThickness="0" SelectedItemChanged="TreeKategoriler_SelectedItemChanged" PreviewMouseLeftButtonUp="TreeKategoriler_PreviewMouseLeftButtonUp" ScrollViewer.VerticalScrollBarVisibility="Hidden" ScrollViewer.HorizontalScrollBarVisibility="Hidden">
                                    <TreeViewItem Header="TÜMÜ" Tag="Tümü" IsSelected="True"/>
                                    <TreeViewItem Header="SİGARALAR" Tag="Ana-Sigaralar">
                                        <TreeViewItem Header="JTI" Tag="Alt-Sigaralar-JTI"/>
                                        <TreeViewItem Header="BAT" Tag="Alt-Sigaralar-BAT"/>
                                        <TreeViewItem Header="Philip Morris" Tag="Alt-Sigaralar-Philip Morris"/>
                                        <TreeViewItem Header="Imperial" Tag="Alt-Sigaralar-Imperial"/>
                                        <TreeViewItem Header="Diğer" Tag="Alt-Sigaralar-Diğer"/>
                                    </TreeViewItem>
                                    <TreeViewItem Header="ALKOLLER" Tag="Ana-Alkoller">
                                        <TreeViewItem Header="Bira" Tag="Alt-Alkoller-Bira"/>
                                        <TreeViewItem Header="Rakı" Tag="Alt-Alkoller-Rakı"/>
                                        <TreeViewItem Header="Viski" Tag="Alt-Alkoller-Viski"/>
                                        <TreeViewItem Header="Votka" Tag="Alt-Alkoller-Votka"/>
                                        <TreeViewItem Header="Şarap" Tag="Alt-Alkoller-Şarap"/>
                                        <TreeViewItem Header="Cin-Tekila-Likör" Tag="Alt-Alkoller-Cin-Tekila-Likör"/>
                                        <TreeViewItem Header="Diğer" Tag="Alt-Alkoller-Diğer"/>
                                    </TreeViewItem>
                                    <TreeViewItem Header="İÇECEKLER" Tag="Ana-İçecekler">
                                        <TreeViewItem Header="Gazlı İçecekler" Tag="Alt-İçecekler-Gazlı İçecekler"/>
                                        <TreeViewItem Header="Soğuk Çaylar" Tag="Alt-İçecekler-Soğuk Çaylar"/>
                                        <TreeViewItem Header="Enerji İçecekleri" Tag="Alt-İçecekler-Enerji İçecekleri"/>
                                        <TreeViewItem Header="Soğuk Kahveler" Tag="Alt-İçecekler-Soğuk Kahveler"/>
                                        <TreeViewItem Header="Meyve Suları" Tag="Alt-İçecekler-Meyve Suları"/>
                                        <TreeViewItem Header="Sular" Tag="Alt-İçecekler-Sular"/>
                                        <TreeViewItem Header="Diğer" Tag="Alt-İçecekler-Diğer"/>
                                    </TreeViewItem>
                                    <TreeViewItem Header="ÇEREZLER" Tag="Ana-Çerezler">
                                        <TreeViewItem Header="Cipsler" Tag="Alt-Çerezler-Cipsler"/>
                                        <TreeViewItem Header="Kuruyemişler" Tag="Alt-Çerezler-Kuruyemişler"/>
                                        <TreeViewItem Header="Diğer" Tag="Alt-Çerezler-Diğer"/>
                                    </TreeViewItem>
                                    <TreeViewItem Header="DONDURMALAR" Tag="Ana-Dondurmalar">
                                        <TreeViewItem Header="Algida" Tag="Alt-Dondurmalar-Algida"/>
                                        <TreeViewItem Header="Diğer" Tag="Alt-Dondurmalar-Diğer"/>
                                    </TreeViewItem>
                                    <TreeViewItem Header="ATIŞTIRMALIKLAR" Tag="Ana-Atıştırmalıklar">
                                        <TreeViewItem Header="Ülker" Tag="Alt-Atıştırmalıklar-Ülker"/>
                                        <TreeViewItem Header="Eti" Tag="Alt-Atıştırmalıklar-Eti"/>
                                        <TreeViewItem Header="Jelibon" Tag="Alt-Atıştırmalıklar-Jelibon"/>
                                        <TreeViewItem Header="Diğer" Tag="Alt-Atıştırmalıklar-Diğer"/>
                                    </TreeViewItem>
                                    <TreeViewItem Header="SAKIZLAR" Tag="Ana-Sakızlar"/>
                                    <TreeViewItem Header="DİĞER" Tag="Ana-Diğer"/>
                                </TreeView>
                            </ScrollViewer>

                            <Button Grid.Row="2" Content="📊 SERMAYE ÖZETİ" Click="BtnSermayeAc_Click" Height="45" Background="#8B5CF6" FontSize="15" Margin="0,15,0,0"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1" Margin="0,0,20,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <TextBox x:Name="TxtStokAra" Height="45" FontSize="16" Padding="15,0" TextChanged="TxtStokAra_TextChanged"/>
                            <TextBlock Text="Stokta ürün ara..." Foreground="#52525B" FontSize="16" VerticalAlignment="Center" Margin="15,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtStokAra}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Border Grid.Row="1" Background="#18181B" CornerRadius="16" Padding="15" Effect="{StaticResource ModernShadow}">
                            <DataGrid x:Name="GridUrunler" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="GridUrunler_SelectionChanged" VirtualizingPanel.ScrollUnit="Pixel">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Barkod" Binding="{Binding Barkod}" Width="130">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FAFAFA"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Ürün Adı" Binding="{Binding Ad}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FAFAFA"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Grup" Binding="{Binding AltKategori}" Width="120">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FAFAFA"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Satış (₺)" Binding="{Binding Fiyat}" Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="2" ShadowDepth="2" Color="Black" Opacity="0.9"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Stok" Binding="{Binding Stok}" Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FAFAFA"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <Border Grid.Column="2" Background="#18181B" CornerRadius="16" Padding="20" Effect="{StaticResource ModernShadow}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ÜRÜN YÖNETİMİ" Foreground="#3B82F6" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                            <TextBlock Text="Barkod" Foreground="#A1A1AA" FontSize="13" Margin="0,0,0,3"/>
                            <TextBox x:Name="InpBarkod" Height="35" Margin="0,0,0,10"/>
                            <TextBlock Text="Kategori" Foreground="#A1A1AA" FontSize="13" Margin="0,0,0,3"/>
                            <ComboBox x:Name="CmbKategori" Height="35" Margin="0,0,0,10" SelectionChanged="CmbKategori_SelectionChanged">
                                <ComboBoxItem Content="Sigaralar"/>
                                <ComboBoxItem Content="Alkoller"/>
                                <ComboBoxItem Content="İçecekler"/>
                                <ComboBoxItem Content="Çerezler"/>
                                <ComboBoxItem Content="Dondurmalar"/>
                                <ComboBoxItem Content="Atıştırmalıklar"/>
                                <ComboBoxItem Content="Sakızlar"/>
                                <ComboBoxItem Content="Diğer"/>
                            </ComboBox>
                            <TextBlock Text="Alt Grup" Foreground="#A1A1AA" FontSize="13" Margin="0,0,0,3"/>
                            <ComboBox x:Name="CmbAltKategori" Height="35" Margin="0,0,0,10"/>
                            <TextBlock Text="Ürün Adı" Foreground="#A1A1AA" FontSize="13" Margin="0,0,0,3"/>
                            <TextBox x:Name="InpUrunAdi" Height="35" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Satış Fiyatı" Foreground="#A1A1AA" FontSize="13" Margin="0,0,0,3"/>
                                    <TextBox x:Name="InpFiyat" Height="35"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Geliş Fiyatı" Foreground="#A1A1AA" FontSize="13" Margin="0,0,0,3"/>
                                    <TextBox x:Name="InpGelisFiyat" Height="35"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Stok Adedi" Foreground="#A1A1AA" FontSize="13" Margin="0,0,0,3"/>
                            <TextBox x:Name="InpStok" Height="35" Margin="0,0,0,15"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="EKLE / KAYDET" Click="BtnKaydet_Click" Height="45" Background="#3B82F6" FontSize="16" Margin="0,0,10,0"/>
                                <Button Grid.Column="1" Content="SİL" Click="BtnStokUrunSil_Click" Height="45" Background="#EF4444" FontSize="16"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="GÜNLÜK CİRO">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#18181B" CornerRadius="16" Padding="15" Margin="0,0,20,0" Effect="{StaticResource ModernShadow}">
                        <StackPanel>
                            <TextBlock Text="SATIŞ GEÇMİŞİ" Foreground="#F59E0B" FontSize="14" FontWeight="Bold" Margin="5,5,0,15"/>
                            <TreeView x:Name="TreeTarihler" Background="Transparent" BorderThickness="0" SelectedItemChanged="TreeTarihler_SelectedItemChanged"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Column="1">
                        <StackPanel>
                            <TextBlock x:Name="TxtSeciliDonem" Text="Dönem Seçimi Bekleniyor..." Foreground="#A1A1AA" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"/>
                            <Border Background="#18181B" CornerRadius="16" Padding="35" Margin="0,0,0,20" Effect="{StaticResource ModernShadow}">
                                <UniformGrid Columns="2">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="TOPLAM CİRO" Foreground="#A1A1AA" FontSize="16" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="TxtCiroSonuc" Text="0.00 ₺" Foreground="White" FontSize="42" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="NET KÂR" Foreground="#10B981" FontSize="16" Margin="0,0,0,5"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                            <TextBlock x:Name="TxtKarSonuc" Text="0.00 ₺" Foreground="#10B981" FontSize="42" FontWeight="Bold" Margin="0,0,15,0"/>
                                            <Border Background="#064E3B" CornerRadius="8" Padding="10,5" VerticalAlignment="Center">
                                                <TextBlock x:Name="TxtKarYuzde" Text="%0.0" Foreground="#34D399" FontSize="18" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </UniformGrid>
                            </Border>
                            <UniformGrid Columns="3" Height="120">
                                <Border Background="#064E3B" CornerRadius="16" Margin="0,0,10,0">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="NAKİT" Foreground="#6EE7B7" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="TxtNakitDetay" Text="0.00 ₺" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#1E3A8A" CornerRadius="16" Margin="10,0">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="KART" Foreground="#93C5FD" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="TxtKartDetay" Text="0.00 ₺" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#78350F" CornerRadius="16" Margin="10,0,0,0">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="VERESİYE" Foreground="#FDBA74" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="TxtVeresiyeDetay" Text="0.00 ₺" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="İSTATİSTİKLER">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#18181B" CornerRadius="16" Margin="0,0,20,0" Padding="15" Effect="{StaticResource ModernShadow}">
                        <StackPanel>
                            <TextBlock Text="ANALİZ MENÜSÜ" Foreground="#10B981" FontSize="14" FontWeight="Bold" Margin="5,5,0,15"/>
                            <ListBox x:Name="ListIstatistikMenu" Background="Transparent" BorderThickness="0" SelectionChanged="ListIstatistikMenu_SelectionChanged">
                                <ListBoxItem Content="Popüler Ürünler" Foreground="#FAFAFA" FontSize="16" Padding="10,12" IsSelected="True" Margin="0,0,0,5"/>
                                <ListBoxItem Content="Saatlik Satış Analizi" Foreground="#FAFAFA" FontSize="16" Padding="10,12" Margin="0,0,0,5"/>
                                <ListBoxItem Content="Günlük Satış Analizi" Foreground="#FAFAFA" FontSize="16" Padding="10,12"/>
                            </ListBox>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#18181B" CornerRadius="16" Padding="25" Effect="{StaticResource ModernShadow}">
                        <Grid>
                            <Grid x:Name="GridPopulerUrunlerPaneli">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                    <TextBlock Text="EN ÇOK KÂR GETİREN İLK 10 ÜRÜN" Foreground="#F59E0B" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="Dükkanın lokomotif ürünleri" Foreground="#A1A1AA" FontSize="14" Margin="0,5,0,0"/>
                                </StackPanel>
                                <DataGrid Grid.Row="1" x:Name="GridPopuler" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="65" VirtualizingPanel.ScrollUnit="Pixel">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Ürün Adı" Binding="{Binding Ad}" Width="*"/>
                                        <DataGridTextColumn Header="Satış Adedi" Binding="{Binding Adet}" Width="150"/>
                                        <DataGridTextColumn Header="Toplam Kâr (₺)" Binding="{Binding ToplamKarStr}" Width="200"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                            <Grid x:Name="GridSaatlikAnalizPaneli" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                    <TextBlock Text="SAATLİK SATIŞ YOĞUNLUĞU" Foreground="#3B82F6" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="Dükkanın en yoğun olduğu saatleri tespit edin" Foreground="#A1A1AA" FontSize="14" Margin="0,5,0,0"/>
                                </StackPanel>
                                <Border Grid.Row="1" Background="#09090B" CornerRadius="12" Padding="20">
                                    <ItemsControl x:Name="ListSaatlik" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid VerticalAlignment="Bottom" Margin="8,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Text="{Binding CiroStr}" Foreground="#10B981" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,8">
                                                        <TextBlock.LayoutTransform>
                                                            <RotateTransform Angle="-45" CenterX="0" CenterY="0"/>
                                                        </TextBlock.LayoutTransform></TextBlock>
                                                    <Rectangle Grid.Row="1" Fill="#3B82F6" Width="35" Height="{Binding BarHeight}" RadiusX="4" RadiusY="4" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                                    <TextBlock Grid.Row="2" Text="{Binding Saat}" Foreground="#A1A1AA" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Grid>
                            <Grid x:Name="GridGunlukAnalizPaneli" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                    <TextBlock Text="HAFTANIN GÜNLERİNE GÖRE SATIŞ (SON 3 AY)" Foreground="#8B5CF6" FontSize="24" FontWeight="Bold"/>
                                    <TextBlock Text="Hangi günün daha yoğun olduğunu enflasyon etkisinden uzak takip edin" Foreground="#A1A1AA" FontSize="14" Margin="0,5,0,0"/>
                                </StackPanel>
                                <Border Grid.Row="1" Background="#09090B" CornerRadius="12" Padding="20">
                                    <ItemsControl x:Name="ListGunluk" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid VerticalAlignment="Bottom" Margin="12,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Text="{Binding CiroStr}" Foreground="#10B981" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8">
                                                        <TextBlock.LayoutTransform>
                                                            <RotateTransform Angle="-45" CenterX="0" CenterY="0"/>
                                                        </TextBlock.LayoutTransform></TextBlock>
                                                    <Rectangle Grid.Row="1" Fill="#8B5CF6" Width="60" Height="{Binding BarHeight}" RadiusX="4" RadiusY="4" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                                    <TextBlock Grid.Row="2" Text="{Binding GunGosterim}" Foreground="#FAFAFA" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="BİLDİRİMLER">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                        <Button x:Name="BtnStokBildirimToggle" Content="STOK BİLDİRİMLERİ: KAPALI" Click="BtnStokBildirimToggle_Click" Background="#52525B" Height="50" Padding="25,0" FontSize="16"/>
                        <TextBlock x:Name="TxtBildirimDurum" Text="Stok takibi kapalı." Foreground="#A1A1AA" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0"/>
                    </StackPanel>
                    <Border Grid.Row="1" Background="#18181B" CornerRadius="16" Padding="20" Effect="{StaticResource ModernShadow}">
                        <ListBox x:Name="ListBildirimler" Background="Transparent" BorderThickness="0" VirtualizingPanel.ScrollUnit="Pixel">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#27272A" BorderThickness="1" BorderBrush="#3F3F46" CornerRadius="10" Margin="0,0,0,10" Padding="20">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="16" Height="16" Fill="{Binding Renk}" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Mesaj}" Foreground="#FAFAFA" FontSize="18" FontWeight="Medium" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="AJANDA / NOTLAR">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="AJANDA &amp; NOT PANOSU" FontSize="24" FontWeight="Bold" Foreground="#8B5CF6" VerticalAlignment="Center"/>
                        <Button Content="+ YENİ NOT EKLE" Click="BtnYeniNotAc_Click" HorizontalAlignment="Right" Background="#10B981" Height="45" Padding="25,0" FontSize="16"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" VirtualizingPanel.ScrollUnit="Pixel">
                        <ItemsControl x:Name="ListNotlar" Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="320" Height="250" Background="#18181B" BorderThickness="1" BorderBrush="#3F3F46" CornerRadius="12" Margin="0,0,20,20" Padding="20" Effect="{StaticResource ModernShadow}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                                <TextBlock Text="{Binding Tarih}" Foreground="#10B981" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                                <Button Content="SİL" Click="BtnNotSil_Click" Background="#EF4444" HorizontalAlignment="Right" Width="50" Height="30" FontSize="12"/>
                                            </Grid>

                                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                                <TextBlock Text="{Binding Metin}" Foreground="#FAFAFA" FontSize="16" TextWrapping="Wrap"/>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>