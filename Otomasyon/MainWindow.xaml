<Window x:Class="Otomasyon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kaleli Tekel Analitik Yönetim" 
        WindowState="Maximized" 
        Background="#09090B" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Tahoma, sans-serif" TextElement.Foreground="#FAFAFA"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <DropShadowEffect x:Key="ModernShadow" BlurRadius="25" ShadowDepth="4" Opacity="0.3" Color="Black" Direction="270"/>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb MinHeight="40">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#52525B" CornerRadius="4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="Foreground" Value="#FAFAFA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#27272A"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="border" Property="Background" Value="#202024"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="0.5" CenterY="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="55"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Foreground" Value="#FAFAFA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent" SnapsToDevicePixels="True">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center">
                                <ContentPresenter.Effect>
                                    <DropShadowEffect BlurRadius="2" ShadowDepth="2" Color="Black" Opacity="0.9"/>
                                </ContentPresenter.Effect>
                            </ContentPresenter>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3B82F6"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="Foreground" Value="#FAFAFA"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="DGR_Border" Background="{TemplateBinding Background}" BorderBrush="#52525B" BorderThickness="0,0,0,2" CornerRadius="8" Padding="0,5">
                            <SelectiveScrollingGrid>
                                <DataGridCellsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </SelectiveScrollingGrid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#27272A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,10,10,20"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Margin="5,0,5,15" Padding="25,12" CornerRadius="8" Background="Transparent" Cursor="Hand">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#27272A"/>
                                <Setter Property="TextElement.Foreground" Value="#10B981"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#FAFAFA"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="IsExpanded" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="Bd" CornerRadius="8" Background="Transparent" Padding="8" TextElement.Foreground="{TemplateBinding Foreground}">
                                <StackPanel Orientation="Horizontal">
                                    <Path x:Name="Arrow" Data="M 0 0 L 5 5 L 0 10 Z" Fill="#71717A" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <Ellipse x:Name="Bullet" Width="5" Height="5" Fill="#52525B" Margin="5,0,10,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                                    <ContentPresenter x:Name="PART_Header" ContentSource="Header"/>
                                </StackPanel>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Visibility="Collapsed" Margin="15,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="Bullet" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Arrow" Property="Data" Value="M 0 0 L 10 0 L 5 5 Z"/>
                                <Setter TargetName="Arrow" Property="Fill" Value="#10B981"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#27272A"/>
                                <Setter Property="Foreground" Value="#10B981"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Arrow" Property="Fill" Value="#10B981"/>
                                <Setter TargetName="Bullet" Property="Fill" Value="#10B981"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#18181B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="DarkComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton Name="ToggleButton" Grid.Column="2" Focusable="false" ClickMode="Press" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}">
                    <ToggleButton.Template>
                        <ControlTemplate>
                            <Border x:Name="Border" Background="#18181B" CornerRadius="8" BorderThickness="1" BorderBrush="#27272A">
                                <Path x:Name="Arrow" Fill="#A1A1AA" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" Data="M 0 0 L 5 5 L 10 0 Z"/>
                            </Border>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
                <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" Margin="12,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                    <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="250" Margin="0,5,0,0">
                        <Border x:Name="DropDownBorder" Background="#18181B" BorderThickness="1" BorderBrush="#3F3F46" CornerRadius="8" Effect="{StaticResource ModernShadow}"/>
                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                        </ScrollViewer>
                    </Grid>
                </Popup>
            </Grid>
        </ControlTemplate>
        <Style TargetType="ComboBox">
            <Setter Property="Template" Value="{StaticResource DarkComboBoxTemplate}"/>
            <Setter Property="Foreground" Value="#FAFAFA"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FAFAFA"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#27272A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Button x:Name="BtnAyarlarAc" Content="⚙ AYARLAR" Click="BtnAyarlarAc_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,20,0" Background="#18181B" BorderThickness="1" BorderBrush="#3F3F46" Foreground="#A1A1AA" FontSize="14" Height="40" Padding="15,0" Panel.ZIndex="50"/>

        <Border x:Name="OverlayAyarlar" Background="#CC000000" Visibility="Collapsed" Panel.ZIndex="200">
            <Border Background="#18181B" Width="400" Height="250" CornerRadius="20" Padding="35" VerticalAlignment="Center" HorizontalAlignment="Center" Effect="{StaticResource ModernShadow}" BorderThickness="1" BorderBrush="#27272A">
                <StackPanel>
                    <TextBlock Text="SİSTEM AYARLARI" Foreground="#3B82F6" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,25"/>
                    <Button x:Name="BtnTamEkranToggle" Content="TAM EKRAN MODU: KAPALI" Click="BtnTamEkranToggle_Click" Height="50" Background="#52525B" FontSize="16" Margin="0,0,0,20"/>
                    <Button Content="KAPAT" Click="BtnAyarlarKapat_Click" Height="45" Background="#EF4444" FontSize="16"/>
                </StackPanel>
            </Border>
        </Border>

        <Border x:Name="OverlaySermaye" Background="#CC000000" Visibility="Collapsed" Panel.ZIndex="250">
            <Border Background="#18181B" Width="600" Height="550" CornerRadius="20" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center" Effect="{StaticResource ModernShadow}" BorderThickness="1" BorderBrush="#27272A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="SERMAYE VE ENVANTER ÖZETİ" Foreground="#8B5CF6" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <DataGrid Grid.Row="1" x:Name="GridSermaye" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="45" Background="Transparent" Margin="0,0,0,15" VirtualizingPanel.ScrollUnit="Pixel">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kategori" Binding="{Binding Kategori}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FAFAFA"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Toplam Geliş Fiyatı" Binding="{Binding MaliyetStr}" Width="160">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FAFAFA"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Toplam Satış Fiyatı" Binding="{Binding SatisStr}" Width="160">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FAFAFA"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="#27272A" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DÜKKAN TOPLAM GELİŞ FİYATI" Foreground="#A1A1AA" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtSermayeMaliyet" Text="0.00 ₺" Foreground="#EF4444" FontSize="24" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="DÜKKAN TOPLAM SATIŞ FİYATI" Foreground="#A1A1AA" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtSermayeSatis" Text="0.00 ₺" Foreground="#10B981" FontSize="24" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Button Grid.Row="3" Content="PENCEREYİ KAPAT" Click="BtnSermayeKapat_Click" Height="45" Background="#52525B" FontSize="16"/>
                </Grid>
            </Border>
        </Border>

        <Border x:Name="OverlayYeniNot" Background="#CC000000" Visibility="Collapsed" Panel.ZIndex="300">
            <Border Background="#18181B" Width="550" Height="400" CornerRadius="20" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center" Effect="{StaticResource ModernShadow}" BorderThickness="1" BorderBrush="#27272A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="YENİ NOT OLUŞTUR" Foreground="#10B981" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBox Grid.Row="1" x:Name="InpNotMetin" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="15" FontSize="16" Margin="0,0,0,20"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="KAYDET" Click="BtnNotKaydet_Click" Height="50" Background="#3B82F6" FontSize="16" Margin="0,0,10,0"/>
                        <Button Grid.Column="1" Content="İPTAL" Click="BtnYeniNotKapat_Click" Height="50" Background="#EF4444" FontSize="16" Margin="10,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>
        </Border>

        <TabControl x:Name="MainTabs" Background="Transparent" BorderThickness="0" SelectionChanged="MainTabs_SelectionChanged" Margin="10,15,10,10">

            <TabItem Header="SATIŞ">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="400"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="OverlayParcali" Grid.ColumnSpan="2" Background="#CC000000" Visibility="Collapsed" Panel.ZIndex="100">
                        <Border Background="#18181B" Width="480" Height="360" CornerRadius="20" Padding="35" VerticalAlignment="Center" HorizontalAlignment="Center" Effect="{StaticResource ModernShadow}" BorderThickness="1" BorderBrush="#27272A">
                            <StackPanel>
                                <TextBlock Text="PARÇALI ÖDEME" Foreground="#10B981" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock x:Name="TxtParcaliToplam" Text="Toplam: 0.00 ₺" Foreground="White" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                                <Grid Margin="0,0,0,30">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Nakit Alınan" Foreground="#A1A1AA" FontSize="14" Margin="0,0,0,5"/>
                                        <TextBox x:Name="InpParcaliNakit" Height="55" FontSize="26" FontWeight="Bold" Background="#09090B" Foreground="#10B981" TextChanged="InpParcaliNakit_TextChanged" HorizontalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="Karttan Çekilen" Foreground="#A1A1AA" FontSize="14" Margin="0,0,0,5"/>
                                        <TextBox x:Name="InpParcaliKart" Height="55" FontSize="26" Foreground="#3B82F6" FontWeight="Bold" Background="#09090B" TextChanged="InpParcaliKart_TextChanged" HorizontalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="ONAYLA" Click="BtnParcaliOnayla_Click" Height="50" Background="#10B981" Margin="0,0,8,0"/>
                                    <Button Grid.Column="1" Content="İPTAL" Click="BtnParcaliIptal_Click" Height="50" Background="#EF4444" Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Border>

                    <Border Grid.Column="0" Background="#18181B" CornerRadius="16" Margin="0,0,20,0" Padding="20" Effect="{StaticResource ModernShadow}">
                        <DockPanel>
                            <TextBox x:Name="TxtHiddenInput" Width="0" Height="0" PreviewKeyDown="TxtHiddenInput_PreviewKeyDown" DockPanel.Dock="Top"/>

                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                                <Grid>
                                    <TextBox x:Name="TxtUrunAra" Height="45" FontSize="18" Padding="15,0" TextChanged="TxtUrunAra_TextChanged"/>
                                    <TextBlock Text="Barkodsuz Ürün Ara..." Foreground="#52525B" FontSize="16" VerticalAlignment="Center" Margin="15,0" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=TxtUrunAra}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <ListBox x:Name="ListAramaSonuclari" MaxHeight="250" Background="#09090B" BorderThickness="1" BorderBrush="#27272A" Margin="0,5,0,0" Visibility="Collapsed" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingPanel.ScrollUnit="Pixel">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8" Background="#18181B" Margin="5" Padding="15,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Ad}" Foreground="White" FontSize="16" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Fiyat, StringFormat={}{0:N2} ₺}" Foreground="#10B981" FontSize="18" FontWeight="Bold" Margin="15,0" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2" Content="EKLE" Click="BtnAramaEkle_Click" Background="#3B82F6" Padding="15,8" FontSize="14"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <Grid DockPanel.Dock="Bottom" Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="SEÇİLİYİ SİL" Click="BtnUrunSil_Click" Width="140" Height="45" Background="#EF4444" FontSize="14"/>
                                <TextBlock Grid.Column="1" x:Name="TxtToplam" Text="TOPLAM: 0.00 ₺" Foreground="#10B981" FontSize="32" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <ListBox x:Name="ListSatis" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingPanel.ScrollUnit="Pixel">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#27272A" CornerRadius="12" Margin="0,0,0,10" Padding="20,15" BorderThickness="1" BorderBrush="#3F3F46">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Ad}" Foreground="White" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Fiyat, StringFormat=Birim: {0:N2} ₺}" Foreground="#A1A1AA" FontSize="13" Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <Border Grid.Column="1" Background="#18181B" CornerRadius="8" Padding="5" Margin="15,0" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="-" Click="BtnAdetAzalt_Click" Width="35" Height="35" Background="Transparent" Foreground="#A1A1AA" FontSize="20" />
                                                        <TextBlock Text="{Binding Adet}" Width="40" TextAlignment="Center" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        <Button Content="+" Click="BtnAdetArtir_Click" Width="35" Height="35" Background="Transparent" Foreground="#10B981" FontSize="20" />
                                                    </StackPanel>
                                                </Border>

                                                <TextBlock Grid.Column="2" Text="{Binding ToplamFiyatStr}" Foreground="#FAFAFA" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
